#!/usr/bin/env python3
"""
bin/check-deps: Analyze which pip packages are used by dimos source files.

For each pip package in pyproject.toml, shows which source files use it
(directly or indirectly via intra-dimos imports). Packages with no users
are flagged as candidates for removal.

Usage:
    bin/check-deps [--json] [--package PACKAGE_NAME]

Options:
    --json              Output results as JSON
    --package NAME      Show details for a specific pip package only
    --unused-only       Only show unused packages
"""

import argparse
import ast
from collections import defaultdict
import json
from pathlib import Path
import sys

try:
    import tomllib
except ImportError:
    print("ERROR: tomllib required (Python 3.11+)", file=sys.stderr)
    sys.exit(1)

REPO_ROOT = Path(__file__).resolve().parent.parent
DIMOS_ROOT = REPO_ROOT / "dimos"
PYPROJECT = REPO_ROOT / "pyproject.toml"

