<?xml version="1.0"?>
<robot name="piper_six_dof">
  <!-- Minimal 6-DoF arm with simple box links for IK and collision -->
  <link name="base_link">
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="1"/><inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/></inertial>
    <visual><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="0.08 0.08 0.04"/></geometry><material name="gray"><color rgba="0.6 0.6 0.6 1"/></material></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/><geometry><box size="0.08 0.08 0.04"/></geometry></collision>
  </link>

  <link name="link1">
    <inertial><origin xyz="0 0 0.05" rpy="0 0 0"/><mass value="1"/><inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/></inertial>
    <visual><origin xyz="0 0 0.05" rpy="0 0 0"/><geometry><box size="0.05 0.05 0.1"/></geometry><material name="blue"><color rgba="0.2 0.4 0.9 1"/></material></visual>
    <collision><origin xyz="0 0 0.05" rpy="0 0 0"/><geometry><box size="0.05 0.05 0.1"/></geometry></collision>
  </link>
  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2.0"/>
  </joint>

  <link name="link2">
    <inertial><origin xyz="0 0 0.08" rpy="0 0 0"/><mass value="1"/><inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/></inertial>
    <visual><origin xyz="0 0 0.08" rpy="0 0 0"/><geometry><box size="0.05 0.05 0.16"/></geometry><material name="green"><color rgba="0.2 0.8 0.2 1"/></material></visual>
    <collision><origin xyz="0 0 0.08" rpy="0 0 0"/><geometry><box size="0.05 0.05 0.16"/></geometry></collision>
  </link>
  <joint name="joint2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.1" upper="2.1" effort="10" velocity="2.0"/>
  </joint>

  <link name="link3">
    <inertial><origin xyz="0 0 0.08" rpy="0 0 0"/><mass value="1"/><inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/></inertial>
    <visual><origin xyz="0 0 0.08" rpy="0 0 0"/><geometry><box size="0.05 0.05 0.16"/></geometry><material name="orange"><color rgba="0.9 0.5 0.2 1"/></material></visual>
    <collision><origin xyz="0 0 0.08" rpy="0 0 0"/><geometry><box size="0.05 0.05 0.16"/></geometry></collision>
  </link>
  <joint name="joint3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.8" upper="2.8" effort="10" velocity="2.0"/>
  </joint>

  <link name="link4">
    <inertial><origin xyz="0 0 0.06" rpy="0 0 0"/><mass value="0.6"/><inertia ixx="7e-4" ixy="0" ixz="0" iyy="7e-4" iyz="0" izz="7e-4"/></inertial>
    <visual><origin xyz="0 0 0.06" rpy="0 0 0"/><geometry><box size="0.045 0.045 0.12"/></geometry><material name="purple"><color rgba="0.6 0.2 0.9 1"/></material></visual>
    <collision><origin xyz="0 0 0.06" rpy="0 0 0"/><geometry><box size="0.045 0.045 0.12"/></geometry></collision>
  </link>
  <joint name="joint4" type="revolute">
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2.0"/>
  </joint>

  <link name="link5">
    <inertial><origin xyz="0 0 0.04" rpy="0 0 0"/><mass value="0.5"/><inertia ixx="5e-4" ixy="0" ixz="0" iyy="5e-4" iyz="0" izz="5e-4"/></inertial>
    <visual><origin xyz="0 0 0.04" rpy="0 0 0"/><geometry><box size="0.04 0.04 0.08"/></geometry><material name="yellow"><color rgba="0.9 0.9 0.2 1"/></material></visual>
    <collision><origin xyz="0 0 0.04" rpy="0 0 0"/><geometry><box size="0.04 0.04 0.08"/></geometry></collision>
  </link>
  <joint name="joint5" type="revolute">
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="0 0 0.12" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2.0"/>
  </joint>

  <link name="link6">
    <inertial><origin xyz="0 0 0.03" rpy="0 0 0"/><mass value="0.4"/><inertia ixx="4e-4" ixy="0" ixz="0" iyy="4e-4" iyz="0" izz="4e-4"/></inertial>
    <visual><origin xyz="0 0 0.03" rpy="0 0 0"/><geometry><box size="0.035 0.035 0.06"/></geometry><material name="red"><color rgba="0.9 0.2 0.2 1"/></material></visual>
    <collision><origin xyz="0 0 0.03" rpy="0 0 0"/><geometry><box size="0.035 0.035 0.06"/></geometry></collision>
  </link>
  <joint name="joint6" type="revolute">
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2.0"/>
  </joint>

  <link name="gripper_base">
    <inertial><origin xyz="0 0 0.02" rpy="0 0 0"/><mass value="0.2"/><inertia ixx="2e-4" ixy="0" ixz="0" iyy="2e-4" iyz="0" izz="2e-4"/></inertial>
    <visual><origin xyz="0 0 0.02" rpy="0 0 0"/><geometry><box size="0.03 0.03 0.04"/></geometry><material name="white"><color rgba="0.95 0.95 0.95 1"/></material></visual>
    <collision><origin xyz="0 0 0.02" rpy="0 0 0"/><geometry><box size="0.03 0.03 0.04"/></geometry></collision>
  </link>
  <joint name="ee_fixed" type="fixed">
    <parent link="link6"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>
</robot>
